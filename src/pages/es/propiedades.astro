---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PropertyCard from '../../components/PropertyCard.astro';
import { useTranslations } from '../../i18n/index';

const t = useTranslations('es');
---

<BaseLayout title={t('seo.properties_title')} description={t('seo.properties_description')}>
  <section class="properties-page" id="properties">
    <div class="container">
      <h1 class="page-title">{t('properties.title')}</h1>

      <!-- Filters -->
      <div class="properties-filters">
        <button class="filter-btn filter-btn--active">{t('properties.filter_all')}</button>
        <button class="filter-btn">{t('properties.filter_rent')}</button>
        <button class="filter-btn">{t('properties.filter_sale')}</button>
      </div>

      <!-- Grid -->
      <div class="properties-grid">
        <PropertyCard title="Depto Vista Horizonte" price="$650.000 CLP/mes" address="Av. Balmaceda, Antofagasta" type="arriendo" typeLabel={t('properties.badge_rent')} beds="2" baths="1" area="65 m²" image="https://images.unsplash.com/photo-1522708323590-d24dbb6b0267?w=640&h=400&fit=crop&q=80" />
        <PropertyCard title="Depto Rímini" price="$580.000 CLP/mes" address="Calle Prat, Antofagasta" type="arriendo" typeLabel={t('properties.badge_rent')} beds="1" baths="1" area="45 m²" image="https://images.unsplash.com/photo-1502672260266-1c1ef2d93688?w=640&h=400&fit=crop&q=80" />
        <PropertyCard title="Casa Sector Norte" price="UF 3.200" address="Sector Norte, Antofagasta" type="venta" typeLabel={t('properties.badge_sale')} beds="3" baths="2" area="120 m²" image="https://images.unsplash.com/photo-1600596542815-ffad4c1539a9?w=640&h=400&fit=crop&q=80" />
        <PropertyCard title="Depto Centro" price="$720.000 CLP/mes" address="Centro, Antofagasta" type="arriendo" typeLabel={t('properties.badge_rent')} beds="2" baths="2" area="75 m²" image="https://images.unsplash.com/photo-1560448204-e02f11c3d0e2?w=640&h=400&fit=crop&q=80" />
        <PropertyCard title="Depto Corporativo" price="$850.000 CLP/mes" address="Av. Angamos, Antofagasta" type="arriendo" typeLabel={t('properties.badge_rent')} beds="3" baths="2" area="90 m²" image="https://images.unsplash.com/photo-1600585154340-be6161a56a0c?w=640&h=400&fit=crop&q=80" />
        <PropertyCard title="Casa Jardines del Sur" price="UF 4.500" address="Jardines del Sur, Antofagasta" type="venta" typeLabel={t('properties.badge_sale')} beds="4" baths="3" area="180 m²" image="https://images.unsplash.com/photo-1564013799919-ab600027ffc6?w=640&h=400&fit=crop&q=80" />
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .properties-page { padding: var(--section-padding-y-hero) 0 var(--section-padding-y); }
  
  .page-title {
    font-size: var(--font-size-3xl);
    font-weight: var(--font-weight-black);
    color: var(--color-accent);
    text-align: center;
    margin-bottom: var(--space-4);
    letter-spacing: var(--letter-spacing-tight);
  }

  .page-title::after {
    content: '';
    display: block;
    width: 60px;
    height: 2px;
    background: var(--color-accent);
    margin: var(--space-4) auto 0;
  }

  .properties-filters {
    display: flex;
    gap: var(--space-2);
    justify-content: center;
    margin-bottom: var(--section-gap);
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: var(--space-2) var(--space-6);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-semibold);
    border: 1px solid var(--color-border);
    background: none;
    color: var(--color-text-secondary);
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
    transition: all 0.3s var(--ease-out-expo);
    font-family: var(--font-family);
    border-radius: var(--radius-pill);
    position: relative;
    overflow: hidden;
  }

  .filter-btn:hover {
    color: var(--color-accent);
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  .filter-btn--active {
    background: var(--color-accent);
    color: var(--color-bg);
    border-color: var(--color-accent);
  }

  .properties-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: var(--space-6);
  }

  /* Stagger animation for property cards */
  .properties-grid > :nth-child(1) { animation-delay: 0.05s; }
  .properties-grid > :nth-child(2) { animation-delay: 0.1s; }
  .properties-grid > :nth-child(3) { animation-delay: 0.15s; }
  .properties-grid > :nth-child(4) { animation-delay: 0.2s; }
  .properties-grid > :nth-child(5) { animation-delay: 0.25s; }
  .properties-grid > :nth-child(6) { animation-delay: 0.3s; }
</style>
