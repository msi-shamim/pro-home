---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { useTranslations } from '../../../i18n/index';
const t = useTranslations('es');
---

<BaseLayout title={t('services_detail.maintenance_title') + ' | PRO HOME®'} description={t('services_detail.maintenance_desc')}>
  <section class="service-detail" id="service-mantenimiento">
    <div class="container">
      <a href="/es/servicios" class="service-detail__back">{t('services_detail.back_to_services')}</a>
      <h1 class="service-detail__title">{t('services_detail.maintenance_title')}</h1>
      <p class="service-detail__desc">{t('services_detail.maintenance_desc')}</p>
      <a href="/es/contacto" class="service-detail__cta">{t('services_detail.cta_contact')}</a>
    </div>
  </section>
</BaseLayout>

<style>
  .service-detail { padding: var(--section-padding-y-hero) 0 var(--section-padding-y); }
  .service-detail__back { display: inline-flex; align-items: center; gap: var(--space-2); margin-bottom: var(--space-8); font-size: var(--font-size-sm); color: var(--color-muted); text-decoration: none; transition: color 0.25s var(--ease-out-expo), transform 0.25s var(--ease-out-expo); }
  .service-detail__back:hover { color: var(--color-accent); transform: translateX(-4px); }
  .service-detail__title { font-size: var(--font-size-3xl); font-weight: var(--font-weight-black); color: var(--color-accent); margin-bottom: var(--space-6); letter-spacing: var(--letter-spacing-tight); max-width: 700px; }
  .service-detail__title::after { content: ''; display: block; width: 60px; height: 2px; background: var(--color-accent); margin-top: var(--space-4); }
  .service-detail__desc { font-size: var(--font-size-md); color: var(--color-text-secondary); line-height: var(--line-height-relaxed); max-width: 700px; margin-bottom: var(--space-8); }
  .service-detail__cta { display: inline-block; padding: var(--space-4) var(--space-8); background: var(--color-accent); color: var(--color-bg); font-size: var(--font-size-sm); font-weight: var(--font-weight-bold); text-transform: uppercase; letter-spacing: var(--letter-spacing-wider); text-decoration: none; transition: transform 0.25s var(--ease-out-expo); position: relative; overflow: hidden; }
  .service-detail__cta::after { content: ''; position: absolute; inset: 0; background: linear-gradient(120deg, transparent 30%, rgba(255,255,255,0.2) 50%, transparent 70%); background-size: 200% 100%; opacity: 0; transition: opacity 0.2s ease; }
  .service-detail__cta:hover { transform: scale(1.05); }
  .service-detail__cta:hover::after { opacity: 1; animation: shimmer 1.5s ease infinite; }
</style>
