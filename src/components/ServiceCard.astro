---
interface Props {
  icon: string;
  title: string;
  description: string;
  href: string;
  ctaLabel: string;
}

const { icon, title, description, href, ctaLabel } = Astro.props;
---

<a href={href} class="service-card" id={`service-${icon}`}>
  <!-- Top accent bar -->
  <div class="service-card__bar"></div>

  <!-- Icon in a framed box -->
  <div class="service-card__icon-frame">
    {icon === 'property' && (
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
        <path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z" /><polyline points="9 22 9 12 15 12 15 22" />
      </svg>
    )}
    {icon === 'corporate' && (
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
        <rect x="2" y="7" width="20" height="14" /><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2" />
      </svg>
    )}
    {icon === 'cleaning' && (
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
        <path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5" />
      </svg>
    )}
    {icon === 'repair' && (
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="square">
        <path d="M14.7 6.3a1 1 0 000 1.4l1.6 1.6a1 1 0 001.4 0l3.77-3.77a6 6 0 01-7.94 7.94l-6.91 6.91a2.12 2.12 0 01-3-3l6.91-6.91a6 6 0 017.94-7.94l-3.76 3.76z" />
      </svg>
    )}
  </div>

  <h3 class="service-card__title">{title}</h3>
  <p class="service-card__desc">{description}</p>
  <span class="service-card__cta">{ctaLabel} →</span>
</a>

<style>
  .service-card {
    display: flex;
    flex-direction: column;
    padding: var(--space-10);
    border: 1px solid var(--color-border);
    background: var(--color-bg);
    text-decoration: none;
    position: relative;
    overflow: hidden;
    transition: all var(--transition-normal);
  }

  /* Top accent line */
  .service-card__bar {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 3px;
    background: var(--color-accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform var(--transition-normal);
  }

  /* Hover: invert entire card */
  .service-card:hover {
    background: var(--color-accent);
    border-color: var(--color-accent);
  }

  .service-card:hover .service-card__bar {
    transform: scaleX(1);
  }

  .service-card:hover .service-card__icon-frame {
    border-color: var(--color-bg);
    color: var(--color-bg);
  }

  .service-card:hover .service-card__title {
    color: var(--color-bg);
  }

  .service-card:hover .service-card__desc {
    color: rgba(255, 255, 255, 0.7);
  }

  [data-theme="dark"] .service-card:hover .service-card__desc {
    color: rgba(0, 0, 0, 0.6);
  }

  .service-card:hover .service-card__cta {
    color: var(--color-bg);
  }

  /* Icon frame */
  .service-card__icon-frame {
    width: 72px;
    height: 72px;
    border: 1.5px solid var(--color-accent);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-8);
    color: var(--color-accent);
    transition: all var(--transition-normal);
  }

  .service-card__title {
    font-size: var(--font-size-lg);
    font-weight: var(--font-weight-bold);
    color: var(--color-accent);
    margin-bottom: var(--space-3);
    letter-spacing: var(--letter-spacing-tight);
    line-height: var(--line-height-tight);
    transition: color var(--transition-normal);
  }

  .service-card__desc {
    font-size: var(--font-size-sm);
    color: var(--color-text-secondary);
    line-height: var(--line-height-relaxed);
    flex: 1;
    transition: color var(--transition-normal);
  }

  .service-card__cta {
    margin-top: var(--space-6);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    color: var(--color-accent);
    transition: color var(--transition-normal);
  }
</style>
