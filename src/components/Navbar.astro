---
import ThemeToggle from './ThemeToggle';
import LanguageSwitcher from './LanguageSwitcher';

interface Props {
  lang: 'es' | 'en';
  currentPath: string;
  translations: {
    home: string;
    services: string;
    properties: string;
    contact: string;
    reserve: string;
    whyProHome: string;
  };
  servicesDropdown: {
    property_management: string;
    property_admin: string;
    short_term: string;
    investment: string;
    pro_home_care: string;
    cleaning: string;
    maintenance: string;
    design: string;
    corporate_lodging: string;
  };
}

const { lang, currentPath, translations, servicesDropdown } = Astro.props;
---

<header class="desktop-only navbar" id="desktop-navbar">
  <div class="navbar__inner container">
    <!-- Logo -->
    <a href={`/${lang}`} class="navbar__logo" aria-label="PRO HOME® - Home">
      <img src="/images/assets/Logo.1.png.svg" alt="PRO HOME®" class="navbar__logo-img" />
    </a>

    <!-- Navigation Links -->
    <nav class="navbar__nav" aria-label="Main navigation">
      <a href={`/${lang}`} class:list={['navbar__link', { 'navbar__link--active': currentPath === `/${lang}` || currentPath === `/${lang}/` }]}>
        {translations.home}
      </a>

      <!-- Services Dropdown -->
      <div class="navbar__dropdown" id="services-dropdown">
        <a href={`/${lang}/servicios`} class:list={['navbar__link', { 'navbar__link--active': currentPath.includes('/servicios') }]}>
          {translations.services}
          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="square">
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </a>
        <div class="navbar__dropdown-menu">
          <span class="navbar__dropdown-category">{servicesDropdown.property_management}</span>
          <a href={`/${lang}/servicios/administracion-propiedades`} class="navbar__dropdown-link">{servicesDropdown.property_admin}</a>
          <a href={`/${lang}/servicios/administracion-corto-plazo`} class="navbar__dropdown-link">{servicesDropdown.short_term}</a>
          <a href={`/${lang}/servicios/servicio-de-inversion`} class="navbar__dropdown-link">{servicesDropdown.investment}</a>
          <div class="navbar__dropdown-divider"></div>
          <span class="navbar__dropdown-category">{servicesDropdown.pro_home_care}</span>
          <a href={`/${lang}/servicios/limpieza`} class="navbar__dropdown-link">{servicesDropdown.cleaning}</a>
          <a href={`/${lang}/servicios/mantenimiento`} class="navbar__dropdown-link">{servicesDropdown.maintenance}</a>
          <a href={`/${lang}/servicios/diseno-decoracion`} class="navbar__dropdown-link">{servicesDropdown.design}</a>
          <div class="navbar__dropdown-divider"></div>
          <a href={`/${lang}/servicios/logistica-corporativa`} class="navbar__dropdown-link">{servicesDropdown.corporate_lodging}</a>
        </div>
      </div>

      <a href={`/${lang}/propiedades`} class:list={['navbar__link', { 'navbar__link--active': currentPath.includes('/propiedades') }]}>
        {translations.properties}
      </a>
      <a href={`/${lang}/por-que-pro-home`} class:list={['navbar__link', { 'navbar__link--active': currentPath.includes('/por-que-pro-home') }]}>
        {translations.whyProHome}
      </a>
      <a href={`/${lang}/contacto`} class:list={['navbar__link', { 'navbar__link--active': currentPath.includes('/contacto') }]}>
        {translations.contact}
      </a>
    </nav>

    <!-- Right Controls -->
    <div class="navbar__controls">
      <a href={`/${lang}/reservar`} class="navbar__cta">
        {translations.reserve}
      </a>
      <ThemeToggle client:load />
      <LanguageSwitcher client:load currentLang={lang} currentPath={currentPath} />
    </div>
  </div>
</header>

<style>
  .navbar {
    position: fixed;
    top: 0;
    width: 100%;
    height: var(--navbar-height);
    background: transparent;
    border-bottom: 1px solid transparent;
    z-index: var(--z-sticky);
    transition:
      background-color 0.4s var(--ease-out-expo),
      border-color 0.4s var(--ease-out-expo),
      backdrop-filter 0.4s var(--ease-out-expo);
  }

  /* Scrolled state: Figma glass effect */
  .navbar--scrolled {
    background: rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.2);
  }

  .navbar__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
    gap: var(--space-6);
  }

  /* Logo */
  .navbar__logo {
    text-decoration: none;
    flex-shrink: 0;
  }

  .navbar__logo-img {
    height: 80px;
    width: auto;
    transition: filter 0.3s ease;
    filter: invert(1);
  }

  :global([data-theme="dark"]) .navbar__logo-img {
    filter: none;
  }

  /* Hero overlay: force dark theme variables when over hero section */
  .navbar--over-hero {
    --color-bg: #000000;
    --color-surface: #111111;
    --color-muted: #D3D3D3;
    --color-accent: #FFFFFF;
    --color-text: #F0F0F0;
    --color-text-secondary: #AAAAAA;
    --color-border: #333333;
    --glass-bg: rgba(0, 0, 0, 0.6);
    --glass-border: rgba(255, 255, 255, 0.08);
  }

  .navbar--over-hero .navbar__logo-img {
    filter: none !important;
  }

  /* Nav Links */
  .navbar__nav {
    display: flex;
    align-items: center;
    gap: var(--space-1);
  }

  .navbar__link {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    padding: var(--space-2) var(--space-3);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-medium);
    color: var(--color-text-secondary);
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
    transition: color 0.25s var(--ease-out-expo);
    white-space: nowrap;
    position: relative;
  }

  /* Animated underline on hover */
  .navbar__link::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 50%;
    width: 0;
    height: 1px;
    background: var(--color-accent);
    transition: width 0.3s var(--ease-out-expo), left 0.3s var(--ease-out-expo);
  }

  .navbar__link:hover::after,
  .navbar__link--active::after {
    width: 100%;
    left: 0;
  }

  .navbar__link:hover {
    color: var(--color-accent);
  }

  .navbar__link--active {
    color: var(--color-accent);
    font-weight: var(--font-weight-bold);
  }

  /* Dropdown */
  .navbar__dropdown {
    position: relative;
  }

  .navbar__dropdown-menu {
    position: absolute;
    top: calc(100% + var(--space-2));
    left: calc(-1 * var(--space-4));
    min-width: 280px;
    background: var(--glass-bg);
    backdrop-filter: blur(var(--glass-blur));
    -webkit-backdrop-filter: blur(var(--glass-blur));
    border: 1px solid var(--color-border);
    padding: var(--space-3) 0;
    z-index: var(--z-dropdown);
    box-shadow: var(--shadow-dramatic);
    /* Animation */
    opacity: 0;
    transform: translateY(-8px) scale(0.98);
    pointer-events: none;
    transition:
      opacity 0.25s var(--ease-out-expo),
      transform 0.25s var(--ease-out-expo);
  }

  .navbar__dropdown:hover .navbar__dropdown-menu {
    opacity: 1;
    transform: translateY(0) scale(1);
    pointer-events: auto;
  }

  .navbar__dropdown-category {
    display: block;
    padding: var(--space-2) var(--space-4);
    font-size: var(--font-size-xs);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    color: var(--color-muted);
  }

  .navbar__dropdown-link {
    display: block;
    padding: var(--space-2) var(--space-4);
    font-size: var(--font-size-sm);
    color: var(--color-text);
    text-decoration: none;
    transition: background-color var(--transition-fast), color var(--transition-fast);
  }

  .navbar__dropdown-link:hover {
    background: var(--color-muted-bg);
    color: var(--color-accent);
  }

  .navbar__dropdown-divider {
    height: 1px;
    background: var(--color-border);
    margin: var(--space-2) 0;
  }

  /* Controls */
  .navbar__controls {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-shrink: 0;
  }

  .navbar__cta {
    padding: var(--space-2) var(--space-5);
    background: var(--color-accent);
    color: var(--color-bg);
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
    text-decoration: none;
    border: none;
    position: relative;
    overflow: hidden;
    transition: transform 0.25s var(--ease-out-expo);
  }

  .navbar__cta:hover {
    transform: scale(1.03);
  }

  /* Shimmer sweep on CTA hover */
  .navbar__cta::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      120deg,
      transparent 30%,
      rgba(255, 255, 255, 0.2) 50%,
      transparent 70%
    );
    background-size: 200% 100%;
    opacity: 0;
    transition: opacity 0.2s ease;
  }

  .navbar__cta:hover::after {
    opacity: 1;
    animation: shimmer 1.5s ease infinite;
  }
</style>

<!-- Navbar scroll detection -->
<script is:inline>
  (function() {
    function setupNavbar() {
      var nav = document.getElementById('desktop-navbar');
      if (!nav) return;

      var hero = document.getElementById('hero');

      function onScroll() {
        if (window.scrollY > 50) {
          nav.classList.add('navbar--scrolled');
        } else {
          nav.classList.remove('navbar--scrolled');
        }

        // Hero-aware: force dark navbar styling while over the hero section
        if (hero) {
          var heroBottom = hero.offsetTop + hero.offsetHeight;
          if (window.scrollY < heroBottom - 80) {
            nav.classList.add('navbar--over-hero');
          } else {
            nav.classList.remove('navbar--over-hero');
          }
        }
      }

      window.addEventListener('scroll', onScroll, { passive: true });
      onScroll(); // Check initial state
    }

    setupNavbar();
    document.addEventListener('astro:page-load', setupNavbar);
  })();
</script>

