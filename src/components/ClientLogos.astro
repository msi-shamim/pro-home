---

<section class="clients" id="client-logos" data-reveal>
  <div class="container">
    <h2 class="clients__title">{title}</h2>

    <div class="clients__track">
      <div class="clients__marquee">
        {[...allLogos, ...allLogos].map((logo) => (
          <div class="clients__item">
            <img src={`/images/assets/Brands/${logo.folder}/${logo.file}`} alt="Client logo" loading="lazy" />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .clients {
    padding: var(--section-padding-y) 0;
    overflow: hidden;
  }

  .clients__title {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    color: var(--color-muted);
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .clients__track {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    margin-bottom: var(--space-3);
  }

  .clients__track:last-child {
    margin-bottom: 0;
  }

  .clients__marquee {
    display: flex;
    gap: var(--space-4);
    width: max-content;
    animation: marquee 50s linear infinite;
  }

  .clients__item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 172px;
    padding: 0 var(--space-3);
    transition: transform 0.3s ease;
  }

  .clients__item:hover {
    transform: translateY(-2px);
  }

  .clients__item img {
    height: 160px;
    width: auto;
    max-width: 240px;
    object-fit: contain;
    filter: none;
    transition: filter 0.3s ease;
    mix-blend-mode: multiply;
  }

  :global([data-theme="dark"]) .clients__item img {
    filter: invert(1);
    mix-blend-mode: screen;
  }

  .clients__item:hover img {
    filter: none;
  }

  :global([data-theme="dark"]) .clients__item:hover img {
    filter: invert(1);
    mix-blend-mode: screen;
  }

  @keyframes marquee {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .clients__track:hover .clients__marquee {
    animation-play-state: paused;
  }
</style>
