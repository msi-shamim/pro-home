---
interface Props {
  title: string;
}

const { title } = Astro.props;

const upperLogos = [
  { folder: 'Upper', file: 'clients_1.jpg' },
  { folder: 'Upper', file: 'clients_2.jpg' },
  { folder: 'Upper', file: 'clients_4.jpg' },
  { folder: 'Upper', file: 'clients_5.jpg' },
  { folder: 'Upper', file: 'clients_6.jpg' },
  { folder: 'Upper', file: 'clients_7.jpg' },
  { folder: 'Upper', file: 'clients_8.jpg' },
  { folder: 'Upper', file: 'clients_9.jpg' },
  { folder: 'Upper', file: 'clients_10.jpg' },
  { folder: 'Upper', file: 'clients_11.jpg' },
  { folder: 'Upper', file: 'clients_12.jpg' },
  { folder: 'Upper', file: 'clients_13.jpg' },
  { folder: 'Upper', file: 'clients_14.jpg' },
  { folder: 'Upper', file: 'clients_15.jpg' },
  { folder: 'Upper', file: 'clients_16.jpg' },
  { folder: 'Upper', file: 'clients_17.jpg' },
  { folder: 'Upper', file: 'clients_18.jpg' },
  { folder: 'Upper', file: 'clients_19.jpg' },
];

const downLogos = [
  { folder: 'Down', file: 'clients_20.jpg' },
  { folder: 'Down', file: 'clients_21.jpg' },
  { folder: 'Down', file: 'clients_22.jpg' },
  { folder: 'Down', file: 'clients_23.jpg' },
  { folder: 'Down', file: 'clients_24.jpg' },
  { folder: 'Down', file: 'clients_25.jpg' },
  { folder: 'Down', file: 'clients_26.jpg' },
  { folder: 'Down', file: 'clients_27.jpg' },
  { folder: 'Down', file: 'clients_28.jpg' },
  { folder: 'Down', file: 'clients_29.jpg' },
  { folder: 'Down', file: 'clients_30.jpg' },
  { folder: 'Down', file: 'clients_31.jpg' },
  { folder: 'Down', file: 'clients_32.jpg' },
  { folder: 'Down', file: 'clients_33.jpg' },
  { folder: 'Down', file: 'clients_34.jpg' },
  { folder: 'Down', file: 'clients_35.jpg' },
  { folder: 'Down', file: 'clients_36 (1).jpg' },
];
---

<section class="clients" id="client-logos" data-reveal>
  <div class="container">
    <h2 class="clients__title">{title}</h2>

    <!-- Row 1: Upper logos, scroll left -->
    <div class="clients__track">
      <div class="clients__marquee clients__marquee--left">
        {[...upperLogos, ...upperLogos].map((logo) => (
          <div class="clients__item">
            <img
              src={`/images/assets/Brands/${logo.folder}/${logo.file}`}
              alt="Client logo"
              loading="lazy"
              decoding="async"
              width="160"
              height="80"
            />
          </div>
        ))}
      </div>
    </div>

    <!-- Row 2: Down logos, scroll right -->
    <div class="clients__track">
      <div class="clients__marquee clients__marquee--right">
        {[...downLogos, ...downLogos].map((logo) => (
          <div class="clients__item">
            <img
              src={`/images/assets/Brands/${logo.folder}/${logo.file}`}
              alt="Client logo"
              loading="lazy"
              decoding="async"
              width="160"
              height="80"
            />
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .clients {
    padding: var(--section-padding-y) 0;
    overflow: hidden;
  }

  .clients__title {
    font-size: var(--font-size-sm);
    font-weight: var(--font-weight-bold);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wider);
    color: var(--color-muted);
    text-align: center;
    margin-bottom: var(--space-8);
  }

  .clients__track {
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 8%, black 92%, transparent);
    margin-bottom: var(--space-3);
  }

  .clients__track:last-child {
    margin-bottom: 0;
  }

  .clients__marquee {
    display: flex;
    gap: var(--space-6);
    width: max-content;
    will-change: transform;
  }

  .clients__marquee--left {
    animation: marquee-left 60s linear infinite;
  }

  .clients__marquee--right {
    animation: marquee-right 60s linear infinite;
  }

  .clients__item {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    height: 100px;
    padding: 0 var(--space-2);
    transition: transform 0.3s ease;
  }

  .clients__item:hover {
    transform: translateY(-2px);
  }

  .clients__item img {
    height: 80px;
    width: auto;
    max-width: 160px;
    object-fit: contain;
    filter: none;
    transition: filter 0.3s ease, opacity 0.3s ease;
    mix-blend-mode: multiply;
  }

  :global([data-theme="dark"]) .clients__item img {
    filter: invert(1);
    mix-blend-mode: screen;
  }

  .clients__item:hover img {
    filter: none;
  }

  :global([data-theme="dark"]) .clients__item:hover img {
    filter: invert(1);
    mix-blend-mode: screen;
  }

  @keyframes marquee-left {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  @keyframes marquee-right {
    0% { transform: translateX(-50%); }
    100% { transform: translateX(0); }
  }

  .clients__track:hover .clients__marquee {
    animation-play-state: paused;
  }

  /* ── Tablet ── */
  @media (max-width: 1024px) {
    .clients__item {
      height: 80px;
      padding: 0 var(--space-1);
    }

    .clients__item img {
      height: 60px;
      max-width: 120px;
    }

    .clients__marquee {
      gap: var(--space-4);
    }
  }

  /* ── Mobile ── */
  @media (max-width: 768px) {
    .clients {
      padding: var(--space-6) 0;
    }

    .clients__title {
      margin-bottom: var(--space-3);
      font-size: 0.7rem;
    }

    .clients__item {
      height: 40px;
      padding: 0;
    }

    .clients__item img {
      height: 32px;
      max-width: 80px;
    }

    .clients__marquee {
      gap: var(--space-3);
    }

    .clients__marquee--left {
      animation-duration: 30s;
    }

    .clients__marquee--right {
      animation-duration: 30s;
    }

    .clients__track {
      margin-bottom: var(--space-1);
    }
  }

  /* ── Small mobile ── */
  @media (max-width: 480px) {
    .clients {
      padding: var(--space-5) 0;
    }

    .clients__item {
      height: 36px;
    }

    .clients__item img {
      height: 28px;
      max-width: 64px;
    }

    .clients__marquee {
      gap: var(--space-2);
    }

    .clients__marquee--left {
      animation-duration: 25s;
    }

    .clients__marquee--right {
      animation-duration: 25s;
    }
  }
</style>
